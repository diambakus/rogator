<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1" author="adruida">
        <!-- Create the sequence for the organs table -->
        <createSequence sequenceName="app_seq" startValue="1" incrementBy="1"/>

        <createTable tableName="applications" schemaName="${schemaName}">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true"/>
            </column>
            <column name="name" type="varchar(255)"/>
            <column name="email" type="varchar(255)"/>
            <column name="price" type="decimal"/>
            <column name="status" type="varchar(10)"/>
            <column name="created" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>
    <changeSet id="2" author="adruida">
        <preConditions>
            <tableExists tableName="applications"/>
        </preConditions>
        <addColumn tableName="applications">
            <column name="requested_to_unit_id" type="bigint"/>
        </addColumn>
    </changeSet>
    <changeSet id="3" author="adruida">
        <preConditions>
            <tableExists tableName="applications"/>
        </preConditions>
        <addColumn tableName="applications">
            <column name="assign_to" type="varchar(255)"/>
        </addColumn>
    </changeSet>
    <changeSet id="4" author="adruida">
        <preConditions>
            <columnExists tableName="applications" columnName="assign_to"/>
        </preConditions>
        <renameColumn tableName="applications" oldColumnName="assign_to" newColumnName="assignee_id"/>
    </changeSet>
    <changeSet id="5" author="adruida">
        <preConditions>
            <not>
                <columnExists tableName="applications" columnName="expires_at" />
                <columnExists tableName="applications" columnName="public_id" />
                <columnExists tableName="applications" columnName="service_id" />
            </not>
        </preConditions>
        <addColumn tableName="applications">
            <column name="expires_at" type="timestamp" />
            <column name="public_id" type="bigint" />
            <column name="service_id" type="bigint"/>
        </addColumn>
    </changeSet>
    <changeSet id="6" author="adruida">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="applications" columnName="name" schemaName="rogator" />
        </preConditions>
        <dropColumn tableName="applications" schemaName="rogator" columnName="name" />
    </changeSet>
    <changeSet id="7" author="adruida">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="applications" columnName="requestor_id" />
            </not>
        </preConditions>
        <addColumn tableName="applications">
            <column name="requestor_id" type="varchar(255)"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>